    {"type": "text", "id": "world_t", "x": 60, "y": 300, "width": 330, "height": 70, "text": "World System (world.py + travel.py)\ngenerate_world(seed) → connected location chain\nexecute_travel() → resource drain, hazards, item finds\nAuto-charge +5%/hr, junk finds, Brutal 1.5x drain", "fontSize": 11, "fontFamily": 1, "textAlign": "center", "strokeColor": "#c89450"},
    {"type": "rectangle", "id": "diff", "x": 430, "y": 295, "width": 420, "height": 80, "strokeColor": "#c89450", "backgroundColor": "#0e1122", "fillStyle": "solid", "strokeWidth": 1, "roundness": {"type": 3}},
    {"type": "text", "id": "diff_t", "x": 440, "y": 300, "width": 400, "height": 70, "text": "Difficulty System (difficulty.py)\nMODE_DIFFICULTY: trust/chat, trust/gift, item drops, drain multipliers\nEasy (+5 trust/chat, 30% drops) → Brutal (+2, 8% drops, 1.5x drain)\n10 junk collectible items · ITEM_DESCRIPTIONS for 26 items", "fontSize": 11, "fontFamily": 1, "textAlign": "center", "strokeColor": "#c89450"},
    {"type": "rectangle", "id": "win", "x": 50, "y": 405, "width": 180, "height": 60, "strokeColor": "#5caa78", "backgroundColor": "#111525", "fillStyle": "solid", "strokeWidth": 1, "roundness": {"type": 3}},
