    {"type": "text", "id": "title", "x": 300, "y": 10, "width": 350, "height": 30, "text": "C4 Component — Game Engine", "fontSize": 22, "fontFamily": 1, "textAlign": "center", "strokeColor": "#dce0ee"},
    {"type": "rectangle", "id": "boundary", "x": 30, "y": 50, "width": 840, "height": 470, "strokeColor": "#c89450", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "dashed", "roundness": {"type": 3}},
    {"type": "text", "id": "boundary_t", "x": 50, "y": 55, "width": 600, "height": 20, "text": "Game Engine Container [game.py + commands.py + travel.py + world.py + difficulty.py]", "fontSize": 12, "fontFamily": 1, "strokeColor": "#c89450"},
    {"type": "rectangle", "id": "ctx", "x": 280, "y": 80, "width": 300, "height": 90, "strokeColor": "#c89450", "backgroundColor": "#0e1122", "fillStyle": "solid", "strokeWidth": 2, "roundness": {"type": 3}},
    {"type": "text", "id": "ctx_t", "x": 290, "y": 85, "width": 280, "height": 80, "text": "GameContext\n[Central state dataclass — passed to all handlers]\nplayer, drone, creatures, locations,\nship_ai, tutorial, repair_checklist, rng", "fontSize": 12, "fontFamily": 1, "textAlign": "center", "strokeColor": "#c89450"},
