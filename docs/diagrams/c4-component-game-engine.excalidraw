    {"type": "text", "id": "dispatch_t", "x": 630, "y": 85, "width": 170, "height": 50, "text": "dispatch(ctx, raw)\nCOMMANDS dict lookup\nRoute to handler function", "fontSize": 12, "fontFamily": 1, "textAlign": "center", "strokeColor": "#c89450"},
