    {
      "type": "text", "id": "system_t", "x": 300, "y": 215, "width": 300, "height": 90,
      "text": "Moon Traveler Terminal\n[Software System]\nLocal LLM-powered survival game\nwith AI NPC agents", "fontSize": 14, "fontFamily": 1,
